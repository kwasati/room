---
import Layout from '../../layouts/Layout.astro';
import LessonNav from '../../components/LessonNav.astro';
import BrokerCTA from '../../components/BrokerCTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map(l => ({
    params: {
      slug: l.data.course,
      lesson: l.id.split('/').pop()!,
    }
  }));
}

const { slug, lesson: lessonSlug } = Astro.params;

const courses = await getCollection('courses');
const course = courses.find(c => c.id === slug);
if (!course) return Astro.redirect('/');

const allLessons = (await getCollection('lessons'))
  .filter(l => l.data.course === slug)
  .sort((a, b) => a.data.order - b.data.order);

const currentIndex = allLessons.findIndex(l => l.id.split('/').pop() === lessonSlug);
if (currentIndex === -1) return Astro.redirect(`/${slug}`);

const lesson = allLessons[currentIndex];
const prevLesson = currentIndex > 0 ? allLessons[currentIndex - 1] : null;
const nextLesson = currentIndex < allLessons.length - 1 ? allLessons[currentIndex + 1] : null;
const isSingleLesson = allLessons.length === 1;

const { Content } = await render(lesson);

const navLessons = allLessons.map(l => ({
  id: l.id.split('/').pop()!,
  title: l.data.title,
  duration: l.data.duration,
}));
---

<Layout title={`${lesson.data.title} | ${course.data.title}`} description={`${lesson.data.title} — ${course.data.description}`} ogImage={course.data.thumbnail}>
  <section class="py-6">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {!isSingleLesson && (
        <div class="lg:hidden">
          <LessonNav courseSlug={slug!} courseTitle={course.data.title} lessons={navLessons} currentLessonSlug={lessonSlug!} />
        </div>
      )}

      <div class={isSingleLesson ? 'max-w-4xl mx-auto' : 'flex gap-6'}>
        {!isSingleLesson && (
          <LessonNav courseSlug={slug!} courseTitle={course.data.title} lessons={navLessons} currentLessonSlug={lessonSlug!} />
        )}

        <div class="flex-1 min-w-0">
          <!-- Breadcrumb -->
          <nav class="mb-4">
            <ol class="flex items-center gap-2 text-sm text-gray flex-wrap">
              <li><a href="/" class="hover:text-primary transition-colors">Room</a></li>
              <li class="text-gray-dark">/</li>
              {!isSingleLesson && (
                <>
                  <li><a href={`/${slug}`} class="hover:text-primary transition-colors">{course.data.title}</a></li>
                  <li class="text-gray-dark">/</li>
                </>
              )}
              <li class="text-gray-light">{lesson.data.title}</li>
            </ol>
          </nav>

          <!-- Video -->
          {lesson.data.videoId && (
            <div class="aspect-video rounded-xl overflow-hidden bg-dark-card border border-dark-border mb-6">
              <iframe src={`https://www.youtube.com/embed/${lesson.data.videoId}`} title={lesson.data.title}
                class="w-full h-full" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen />
            </div>
          )}

          <!-- Header -->
          <div class="mb-6">
            {!isSingleLesson && (
              <p class="text-sm text-gray-dark mb-1">บทที่ {currentIndex + 1} จาก {allLessons.length}</p>
            )}
            <h1 class="text-xl lg:text-2xl font-extrabold text-gray-light mb-1">{lesson.data.title}</h1>
            {lesson.data.duration && <p class="text-sm text-gray-dark">{lesson.data.duration}</p>}
          </div>

          <!-- Content -->
          <article class="prose prose-invert max-w-none
            prose-headings:font-bold prose-headings:text-gray-light
            prose-p:text-gray prose-p:leading-relaxed
            prose-a:text-primary prose-a:no-underline hover:prose-a:underline
            prose-strong:text-gray-light
            prose-code:text-primary-light prose-code:bg-dark-card prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
            prose-li:text-gray prose-ol:text-gray prose-ul:text-gray
            prose-table:text-gray prose-th:text-gray-light prose-td:border-dark-border prose-th:border-dark-border">
            <Content />
          </article>

          <!-- Tool Download -->
          {course.data.courseType === 'learn-tool' && course.data.toolDownload && (
            <div class="mt-8 p-5 bg-dark-card border border-dark-border rounded-xl text-center">
              <p class="text-gray-light font-bold mb-1">ดาวน์โหลด {course.data.toolName || 'เครื่องมือ'}</p>
              <p class="text-sm text-gray mb-3">พร้อมใช้งานฟรี</p>
              <a href={course.data.toolDownload} target="_blank" rel="noopener"
                 class="inline-block px-6 py-3 bg-primary hover:bg-primary-dark text-white rounded-lg font-bold transition-colors cursor-pointer">
                ดาวน์โหลดฟรี
              </a>
            </div>
          )}

          <!-- Broker CTA -->
          <BrokerCTA placement="end-of-lesson" />

          <!-- Prev/Next -->
          {!isSingleLesson && (
            <nav class="flex items-center justify-between mt-10 pt-6 border-t border-dark-border">
              {prevLesson ? (
                <a href={`/${slug}/${prevLesson.id.split('/').pop()}`} class="flex items-center gap-2 text-gray hover:text-primary transition-colors cursor-pointer">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                  <div><p class="text-[11px] text-gray-dark">ก่อนหน้า</p><p class="font-medium text-sm">{prevLesson.data.title}</p></div>
                </a>
              ) : <div />}
              {nextLesson ? (
                <a href={`/${slug}/${nextLesson.id.split('/').pop()}`} class="flex items-center gap-2 text-gray hover:text-primary transition-colors text-right cursor-pointer">
                  <div><p class="text-[11px] text-gray-dark">ถัดไป</p><p class="font-medium text-sm">{nextLesson.data.title}</p></div>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              ) : (
                <a href="/" class="flex items-center gap-2 text-gray hover:text-primary transition-colors text-right cursor-pointer">
                  <div><p class="text-[11px] text-gray-dark">จบคอร์ส</p><p class="font-medium text-sm">กลับหน้า Room</p></div>
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
                </a>
              )}
            </nav>
          )}
        </div>
      </div>

      <BrokerCTA placement="mobile-bar" />
    </div>
  </section>
</Layout>
