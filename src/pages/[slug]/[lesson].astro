---
import Layout from '../../layouts/Layout.astro';
import LessonNav from '../../components/LessonNav.astro';
import BrokerCTA from '../../components/BrokerCTA.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map(l => ({
    params: {
      slug: l.data.course,
      lesson: l.id.split('/').pop()!,
    }
  }));
}

const { slug, lesson: lessonSlug } = Astro.params;

const courses = await getCollection('courses');
const course = courses.find(c => c.id === slug);
if (!course) return Astro.redirect('/');

const allLessons = (await getCollection('lessons'))
  .filter(l => l.data.course === slug)
  .sort((a, b) => a.data.order - b.data.order);

const currentIndex = allLessons.findIndex(l => l.id.split('/').pop() === lessonSlug);
if (currentIndex === -1) return Astro.redirect(`/${slug}`);

const lesson = allLessons[currentIndex];
const nextLesson = currentIndex < allLessons.length - 1 ? allLessons[currentIndex + 1] : null;
const isSingleLesson = allLessons.length === 1;

const { Content } = await render(lesson);

const navLessons = allLessons.map(l => ({
  id: l.id.split('/').pop()!,
  title: l.data.title,
  duration: l.data.duration,
}));
---

<Layout title={`${lesson.data.title} | ${course.data.title}`} description={`${lesson.data.title} — ${course.data.description}`} ogImage={course.data.thumbnail}>
  <section class="py-6">
    <div class="max-w-[1100px] mx-auto px-5 max-md:max-w-[640px]">
      <!-- Mobile: inline outline -->
      {!isSingleLesson && (
        <div class="md:hidden">
          <LessonNav courseSlug={slug!} courseTitle={course.data.title} lessons={navLessons} currentLessonSlug={lessonSlug!} />
        </div>
      )}

      <div class={isSingleLesson ? 'max-w-4xl mx-auto' : 'flex gap-7'}>
        {!isSingleLesson && (
          <LessonNav courseSlug={slug!} courseTitle={course.data.title} lessons={navLessons} currentLessonSlug={lessonSlug!} />
        )}

        <div class="flex-1 min-w-0">
          <!-- Breadcrumb -->
          <nav class="mb-5">
            <ol class="flex items-center gap-1.5 text-[13px] text-gray-dark flex-wrap">
              <li><a href="/" class="hover:text-primary transition-colors">Room</a></li>
              <li>/</li>
              {!isSingleLesson && (
                <>
                  <li><a href={`/${slug}`} class="hover:text-primary transition-colors">{course.data.title}</a></li>
                  <li>/</li>
                </>
              )}
              <li class="text-gray-light">{lesson.data.title}</li>
            </ol>
          </nav>

          <!-- Video -->
          {lesson.data.videoId && (
            <div class="aspect-video rounded-[14px] overflow-hidden bg-dark-card border border-dark-border mb-6">
              <iframe src={`https://www.youtube.com/embed/${lesson.data.videoId}`} title={lesson.data.title}
                class="w-full h-full" frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen />
            </div>
          )}

          <!-- Header -->
          <div class="mb-6">
            {!isSingleLesson && (
              <p class="text-[12px] text-gray-dark mb-1.5">บทที่ {currentIndex + 1} จาก {allLessons.length}</p>
            )}
            <h1 class="text-[22px] max-md:text-[20px] font-bold text-gray-light mb-1">{lesson.data.title}</h1>
            {lesson.data.duration && <p class="text-[13px] text-gray-dark">{lesson.data.duration}</p>}
          </div>

          <!-- Content -->
          <article class="prose prose-invert max-w-none
            prose-headings:font-bold prose-headings:text-gray-light
            prose-p:text-gray prose-p:leading-relaxed
            prose-a:text-primary prose-a:no-underline hover:prose-a:underline
            prose-strong:text-gray-light
            prose-code:text-primary-light prose-code:bg-dark-card prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
            prose-li:text-gray prose-ol:text-gray prose-ul:text-gray
            prose-table:text-gray prose-th:text-gray-light prose-td:border-dark-border prose-th:border-dark-border">
            <Content />
          </article>

          <!-- Tool Download -->
          {course.data.courseType === 'learn-tool' && course.data.toolDownload && (
            <div class="mt-8 p-5 bg-dark-card border border-dark-border rounded-[14px] text-center">
              <p class="text-gray-light font-bold mb-1">ดาวน์โหลด {course.data.toolName || 'เครื่องมือ'}</p>
              <p class="text-[13px] text-gray mb-3">พร้อมใช้งานฟรี</p>
              <a href={course.data.toolDownload} target="_blank" rel="noopener"
                 class="inline-block px-6 py-3 bg-primary hover:bg-primary-dark text-white rounded-[10px] font-bold transition-colors cursor-pointer">
                ดาวน์โหลดฟรี
              </a>
            </div>
          )}

          <!-- Broker CTA -->
          <BrokerCTA placement="end-of-lesson" />

          <!-- Next lesson card -->
          {!isSingleLesson && (
            nextLesson ? (
              <a href={`/${slug}/${nextLesson.id.split('/').pop()}`}
                 class="flex items-center gap-3.5 mt-9 p-3.5 bg-dark-card border border-dark-border rounded-[14px] hover:border-primary transition-colors cursor-pointer group">
                <span class="w-9 h-9 rounded-full bg-primary/10 border-[1.5px] border-dark-border flex items-center justify-center text-[13px] font-semibold text-primary shrink-0 group-hover:border-primary">
                  {currentIndex + 2}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="text-[11px] text-gray-dark">ถัดไป</div>
                  <div class="text-[14px] font-semibold group-hover:text-primary transition-colors truncate">{nextLesson.data.title}</div>
                </div>
                <span class="text-gray-dark text-[18px] ml-auto shrink-0 group-hover:text-primary">→</span>
              </a>
            ) : (
              <a href="/"
                 class="flex items-center gap-3.5 mt-9 p-3.5 bg-dark-card border border-dark-border rounded-[14px] hover:border-primary transition-colors cursor-pointer group">
                <span class="w-9 h-9 rounded-full bg-green/10 border-[1.5px] border-dark-border flex items-center justify-center text-[13px] font-semibold text-green shrink-0">
                  ✓
                </span>
                <div class="flex-1 min-w-0">
                  <div class="text-[11px] text-gray-dark">จบคอร์ส</div>
                  <div class="text-[14px] font-semibold group-hover:text-primary transition-colors">กลับหน้า Room</div>
                </div>
                <span class="text-gray-dark text-[18px] ml-auto shrink-0 group-hover:text-primary">→</span>
              </a>
            )
          )}
        </div>
      </div>

      <BrokerCTA placement="mobile-bar" />
    </div>
  </section>
</Layout>
