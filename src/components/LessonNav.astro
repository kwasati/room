---
interface Lesson { id: string; title: string; duration?: string; }
interface Props {
  courseSlug: string;
  courseTitle: string;
  lessons: Lesson[];
  currentLessonSlug: string;
}
const { courseSlug, courseTitle, lessons, currentLessonSlug } = Astro.props;
const currentIndex = lessons.findIndex(l => l.id === currentLessonSlug);
const progressPercent = lessons.length > 0 ? Math.round(((currentIndex + 1) / lessons.length) * 100) : 0;
---

<!-- Desktop sidebar -->
<aside class="hidden md:block w-[280px] flex-shrink-0">
  <div class="sticky top-[72px]">
    <div class="bg-dark-card border border-dark-border rounded-[14px] overflow-hidden">
      <div class="p-3 border-b border-dark-border">
        <a href={`/${courseSlug}`} class="text-[13px] text-gray hover:text-primary transition-colors">← {courseTitle}</a>
      </div>
      <nav class="p-1.5">
        {lessons.map((lesson, i) => {
          const isActive = lesson.id === currentLessonSlug;
          return (
            <a href={`/${courseSlug}/${lesson.id}`}
               class:list={['flex items-center gap-2.5 px-3 py-2.5 rounded-[10px] text-[13px] transition-colors',
                 isActive ? 'bg-primary/10 text-primary' : 'text-gray hover:text-gray-light hover:bg-dark']}>
              <span class:list={['flex-shrink-0 w-[26px] h-[26px] rounded-full flex items-center justify-center text-[11px] border-[1.5px]',
                isActive ? 'border-primary text-primary' : 'border-dark-border text-gray-dark']}>
                {i + 1}
              </span>
              <span class="truncate">{lesson.title}</span>
            </a>
          );
        })}
      </nav>
      <div class="px-3.5 pb-3">
        <div class="h-[3px] bg-dark-border rounded-full overflow-hidden">
          <div class="h-full bg-primary rounded-full" style={`width:${progressPercent}%`}></div>
        </div>
        <div class="text-[11px] text-gray-dark mt-1.5 text-right">{currentIndex + 1} / {lessons.length} บท</div>
      </div>
    </div>
  </div>
</aside>

<!-- Mobile: inline collapsible outline -->
<div class="md:hidden mb-5">
  <div class="bg-dark-card border border-dark-border rounded-[14px] overflow-hidden">
    <button id="lesson-nav-toggle"
      class="w-full flex items-center justify-between px-4 py-3.5 text-[13px] text-gray-light font-medium cursor-pointer">
      <span>สารบัญ — บทที่ {currentIndex + 1} / {lessons.length}</span>
      <span id="lesson-nav-arrow" class="transition-transform">▾</span>
    </button>
    <div id="lesson-nav-mobile" class="hidden">
      <nav class="px-1.5 pb-1.5">
        {lessons.map((lesson, i) => {
          const isActive = lesson.id === currentLessonSlug;
          return (
            <a href={`/${courseSlug}/${lesson.id}`}
               class:list={['flex items-center gap-2.5 px-3 py-2.5 rounded-[10px] text-[13px] transition-colors',
                 isActive ? 'bg-primary/10 text-primary' : 'text-gray hover:text-gray-light hover:bg-dark']}>
              <span class:list={['flex-shrink-0 w-[26px] h-[26px] rounded-full flex items-center justify-center text-[11px] border-[1.5px]',
                isActive ? 'border-primary text-primary' : 'border-dark-border text-gray-dark']}>
                {i + 1}
              </span>
              <span class="truncate">{lesson.title}</span>
            </a>
          );
        })}
      </nav>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('lesson-nav-toggle');
  const mobile = document.getElementById('lesson-nav-mobile');
  const arrow = document.getElementById('lesson-nav-arrow');
  toggle?.addEventListener('click', () => {
    mobile?.classList.toggle('hidden');
    arrow?.classList.toggle('rotate-180');
  });
</script>
