---
interface Props {
  placement: 'end-of-lesson' | 'sidebar' | 'mobile-bar';
}
const { placement } = Astro.props;
const affiliateLink = '#';
---

{placement === 'end-of-lesson' && (
  <section class="mt-10 p-6 bg-dark-card border border-dark-border rounded-xl text-center">
    <p class="text-lg text-gray-light font-bold mb-1">เรียนจบแล้ว พร้อมลองเทรดจริงไหม?</p>
    <p class="text-sm text-gray mb-4">เปิดบัญชีเทรดฟรี — เริ่มฝึกด้วยบัญชี Demo ก่อนได้</p>
    <a href={affiliateLink} target="_blank" rel="noopener noreferrer"
       class="inline-block px-6 py-3 bg-primary hover:bg-primary-dark text-white rounded-lg font-bold transition-colors cursor-pointer">
      เปิดบัญชีเทรดฟรี
    </a>
  </section>
)}

{placement === 'sidebar' && (
  <div class="bg-dark-card border border-dark-border rounded-xl p-5 text-center">
    <p class="text-sm text-gray mb-3">พร้อมลองเทรดจริง?</p>
    <a href={affiliateLink} target="_blank" rel="noopener noreferrer"
       class="block w-full px-4 py-3 bg-primary hover:bg-primary-dark text-white rounded-lg font-bold transition-colors text-sm cursor-pointer">
      เปิดบัญชีฟรี
    </a>
  </div>
)}

{placement === 'mobile-bar' && (
  <div id="broker-bar" class="fixed bottom-0 inset-x-0 lg:hidden bg-dark-card/95 backdrop-blur border-t border-dark-border p-3 flex items-center justify-between z-40">
    <span class="text-sm text-gray-light">พร้อมเทรดจริง?</span>
    <a href={affiliateLink} target="_blank" rel="noopener noreferrer"
       class="px-4 py-2 bg-primary hover:bg-primary-dark text-white rounded-lg text-sm font-bold transition-colors cursor-pointer">
      สมัครฟรี
    </a>
    <button id="broker-bar-close" class="text-gray-dark hover:text-gray-light transition-colors p-1 cursor-pointer" aria-label="ปิด">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
)}

<script>
  const bar = document.getElementById('broker-bar');
  const closeBtn = document.getElementById('broker-bar-close');
  if (bar && localStorage.getItem('broker-bar-closed') === '1') bar.remove();
  closeBtn?.addEventListener('click', () => {
    bar?.remove();
    localStorage.setItem('broker-bar-closed', '1');
  });
</script>
